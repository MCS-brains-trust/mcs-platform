# Django Core
DEBUG=False
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_50_CHAR_STRING
# Field-level encryption key for PII/secrets at rest (TOTP secrets, OAuth tokens).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If blank, a key is derived from SECRET_KEY (not recommended for production).
FIELD_ENCRYPTION_KEY=
DATABASE_URL=postgres://mcs_user:CHANGE_ME@db:5432/mcs_platform
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF Origins (comma-separated)
CSRF_TRUSTED_ORIGINS=https://statementhub.com.au,https://www.statementhub.com.au

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Webhook Authentication (HMAC secret or Bearer token for n8n)
WEBHOOK_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PENDING_TABLE=
AIRTABLE_JOBS_TABLE=
AIRTABLE_LEARNING_TABLE=

# Xero OAuth2
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XPM_SYNC_ENABLED=false

# MYOB OAuth2
MYOB_CLIENT_ID=
MYOB_CLIENT_SECRET=

# QuickBooks Online OAuth2
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# Microsoft Graph API (Email Ingestion)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# IMAP Fallback (Email Ingestion)
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Anthropic Claude (AI Classification)
ANTHROPIC_API_KEY=

# Database SSL (production)
DB_SSLMODE=require
